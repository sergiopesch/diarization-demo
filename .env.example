# Shared app config
TRANSCRIPTION_PROVIDER=whisperx
# Use http://127.0.0.1:8000 when Next.js runs on your host.
# docker-compose.local.yml overrides this to http://local-stt-worker:8000.
LOCAL_TRANSCRIPTION_API_URL=http://127.0.0.1:8000
LOCAL_TRANSCRIPTION_TIMEOUT_MS=600000
# Optional locally, required for production if the worker is reachable over HTTPS.
LOCAL_WORKER_API_KEY=
ASSEMBLYAI_API_KEY=

# Google fallback / baseline
# Keep the value on one line when exporting in a shell or writing to a dotenv file.
GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account","project_id":"your-project-id"}'

# Local worker config
LOCAL_STT_DEVICE=cpu
WHISPERX_MODEL=tiny.en
PYANNOTE_AUTH_TOKEN=
LOCAL_STT_MAX_AUDIO_BYTES=8388608

{
  "name": "diarization-demo",
  "private": true,
  "version": "1.0.0",
  "description": "Browser recording demo for Google Cloud Speech-to-Text diarization.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "next": "^16.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  }
}

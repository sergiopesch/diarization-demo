{
  "name": "diarization-demo",
  "private": true,
  "version": "1.0.0",
  "description": "Browser-based speaker diarization demo with pluggable cloud and local backends.",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run src/lib",
    "test:e2e": "playwright test",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "next": "^16.2.4",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  }
}
